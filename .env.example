# Anthropic API key — from console.anthropic.com
ANTHROPIC_API_KEY=

# Throwaway SIM phone number (e.g. +12125551234) — for logging context only
BOT_PHONE_NUMBER=

# Telegram bot token — from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID — run the bot once and check logs to find it
TELEGRAM_CHAT_ID=

# Brave Search API key — free tier (2,000 searches/month) at brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Comma-separated WhatsApp group JIDs the bot is allowed to respond in.
# Find the JID by checking bot logs after the group sends a message, or via
# sock.groupFetchAllParticipating() on first run.
# Leave empty to allow all groups (not recommended for production).
ALLOWED_GROUP_JIDS=

# Node 20+ required (Baileys v7 hard constraint)
# Run: node --version  =>  should be v20.x or higher
